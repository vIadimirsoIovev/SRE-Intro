{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Request Rate (Traffic)",
      "description": "Golden Signal #2: How much demand is being placed on the system",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Error Rate",
      "description": "Golden Signal #3: Percentage of requests failing with 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(gateway_requests_total{status=~\"5..\"}[1m])) / sum(rate(gateway_requests_total[1m])) * 100",
          "legendFormat": "5xx error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Service Health (up/down)",
      "description": "Prometheus 'up' metric — 1 = scrape succeeded, 0 = target unreachable",
      "type": "table",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "up",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["job", "Value"] } } }
      ]
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "description": "Golden Signal #1: Request duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "seconds",
          "decimals": 3
        }
      }
    },
    {
      "title": "Saturation — Events DB Pool",
      "description": "Golden Signal #4: How full is the database connection pool",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "events_db_pool_size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "red", "value": 9 }
            ]
          }
        }
      }
    },
    {
      "title": "SLO Availability",
      "description": "Current availability against SLO 99.5%",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "gateway:sli_availability:ratio_rate5m * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 99,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["quickticket", "sre"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "QuickTicket — Golden Signals",
  "uid": "quickticket-golden-signals"
}